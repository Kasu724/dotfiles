# Terminal
super + Return
    xfce4-terminal

# Rofi
super + shift + d
    ~/.config/bspwm/scripts/rofi_powermenu.sh
ctrl + shift + space
    ~/.config/bspwm/scripts/rofi_powermenu.sh
super + d
    ~/.config/bspwm/scripts/rofi_launcher.sh
ctrl + space
    ~/.config/bspwm/scripts/rofi_launcher.sh

# Alt+Tab
alt + ~Tab
    ~/.config/bspwm/scripts/alt_tab.sh

# Close window
super + q
    bspc node -c

# Reload sxhkd
super + Escape
    pkill -USR1 -x sxhkd

# Focus windows
super + {Left,Down,Up,Right}
    bspc node -f {west,south,north,east}

# Move windows
super + shift + {Left,Down,Up,Right}
    bspc node -s {west,south,north,east}

# Switch desktops
super + {1-9,0}
    bspc desktop -f '^{1-9,10}'

# Move window to desktop
super + shift + {1-9,0}
    bspc node -d '^{1-9,10}'

# Toggle fullscreen
super + a
    bspc desktop -l next

# Toggle floating
super + z
    bspc node -t ~floating

# Hide/Show window
super + h
    ~/.config/bspwm/scripts/alt_tab.sh --hide
super + j
    ~/.config/bspwm/scripts/alt_tab.sh --show-last
